# pyenv
#   For a library or app, you might want to share this in the project:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you do not want to lock it:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be tracked or ignored.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be tracked or ignored.
#pdm.lock
#   command tracking and caching
.pdm-plugins/
.pdm-build/

# PEP 582; project local packages (e.g. pdm)
__pypackages__/

